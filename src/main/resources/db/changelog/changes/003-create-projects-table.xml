<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="003" author="evdokimov">
        <createTable tableName="projects">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="manager_id" type="BIGINT"/>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="projects" baseColumnNames="manager_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_projects_manager"/>

        <createIndex tableName="projects" indexName="idx_projects_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-1" author="evdokimov">
        <createTable tableName="project_members">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role_in_project" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="project_members" columnNames="project_id, user_id"
                             constraintName="uk_project_member"/>

        <addForeignKeyConstraint baseTableName="project_members" baseColumnNames="project_id"
                                 referencedTableName="projects" referencedColumnNames="id"
                                 constraintName="fk_pm_project" onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="project_members" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_pm_user" onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>